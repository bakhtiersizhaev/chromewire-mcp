{
  "name": "chromewire-mcp",
  "version": "0.1.0",
  "type": "module",
  "description": "ChromeWire MCP connects the official Codex Chrome Extension to MCP-compatible AI CLIs for safe localhost control of real Chrome tabs.",
  "scripts": {
    "start": "node src/server.js",
    "check": "node --check src/config.js && node --check src/redact.js && node --check src/nativeHostManifest.js && node --check src/server.js && node --check src/codexChromePipe.js && node --check scripts/smoke.js && node --check scripts/doctor.js && node --check scripts/install.js && node --check scripts/install-codex-native-host.js",
    "test": "node --test",
    "smoke": "node scripts/smoke.js",
    "doctor": "node scripts/doctor.js",
    "install:agent": "node scripts/install.js",
    "install:codex-native-host": "node scripts/install-codex-native-host.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "classic-level": "^3.0.0",
    "express": "^5.1.0",
    "zod": "^4.1.12"
  },
  "license": "Apache-2.0",
  "author": "Original author (preserve attribution in NOTICE)",
  "homepage": "https://bakhtiersizhaev.github.io/chromewire-mcp/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bakhtiersizhaev/chromewire-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/bakhtiersizhaev/chromewire-mcp/issues"
  },
  "bin": {
    "chromewire-mcp": "./src/server.js",
    "codex-chrome-mcp-bridge": "./src/server.js"
  },
  "files": [
    "src/",
    "scripts/",
    "docs/",
    "examples/",
    "skills/",
    ".github/workflows/ci.yml",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "keywords": [
    "ai-cli",
    "browser-automation",
    "chrome",
    "chrome-extension",
    "chrome-web-store",
    "chromewire",
    "claude-code",
    "codex",
    "codex-chrome-extension",
    "cursor",
    "github-pages",
    "gsd",
    "local-mcp",
    "mcp",
    "mcp-server",
    "official-codex-chrome-extension",
    "pi",
    "real-chrome",
    "windsurf"
  ],
  "engines": {
    "node": ">=20"
  }
}
